<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_pls_cn" model="ir.ui.view">
        <field name="name">res.company.form.pls.cn</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="unified_social_credit_code"/>
                <field name="legal_representative"/>
                <field name="registered_capital"/>
            </xpath>
            <xpath expr="//page[@name='general_info']" position="after">
                <page string="中国银行信息" name="cn_bank_info">
                    <group>
                        <group string="开户信息">
                            <field name="bank_name"/>
                            <field name="bank_account_name"/>
                            <field name="bank_account_number"/>
                        </group>
                    </group>
                </page>
                <page string="经营信息" name="cn_business_info">
                    <group>
                        <field name="business_scope"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
