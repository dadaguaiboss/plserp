<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 继承采购订单 form 视图 -->
    <record id="purchase_order_form_inherit_payment_status" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.payment.status</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_order']" position="after">
                <field name="payment_status"/>
            </xpath>
            <xpath expr="//page[last()]" position="after">
                <page string="付款信息" name="payment_info">
                    <group>
                        <group>
                            <field name="payment_status"/>
                            <field name="paid_amount"/>
                            <field name="remaining_amount"/>
                        </group>
                        <group>
                            <field name="payment_notes"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- 继承采购订单 tree 视图 -->
    <record id="purchase_order_tree_inherit_payment_status" model="ir.ui.view">
        <field name="name">purchase.order.tree.inherit.payment.status</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="payment_status" optional="show"/>
                <field name="paid_amount" optional="hide"/>
                <field name="remaining_amount" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
