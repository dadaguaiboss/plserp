<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 中文报表外部布局模板 -->
    <template id="prolion_cn_external_layout" inherit_id="web.external_layout_standard" name="ProLion CN Report Layout">
        <xpath expr="//div[@name='company_address']" position="after">
            <div t-if="company.unified_social_credit_code" class="mt-1">
                <span>统一社会信用代码: </span>
                <span t-field="company.unified_social_credit_code"/>
            </div>
            <div t-if="company.bank_name" class="mt-1">
                <span>开户银行: </span>
                <span t-field="company.bank_name"/>
                <span t-if="company.bank_account_number"> | 账号: </span>
                <span t-if="company.bank_account_number" t-field="company.bank_account_number"/>
            </div>
        </xpath>
    </template>

</odoo>
