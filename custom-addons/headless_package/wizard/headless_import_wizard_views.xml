<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 导入向导 Form 视图 -->
    <record id="headless_import_wizard_view_form" model="ir.ui.view">
        <field name="name">headless.import.wizard.form</field>
        <field name="model">headless.import.wizard</field>
        <field name="arch" type="xml">
            <form string="批量导入无头件">
                <group>
                    <group>
                        <field name="warehouse_id"/>
                        <field name="file" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                </group>
                <group invisible="not import_result">
                    <field name="import_result" readonly="1"/>
                </group>
                <footer>
                    <button name="action_import" type="object"
                            string="导入" class="oe_highlight"
                            invisible="import_result"/>
                    <button string="关闭" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- 导入向导 Action -->
    <record id="headless_import_wizard_action" model="ir.actions.act_window">
        <field name="name">批量导入无头件</field>
        <field name="res_model">headless.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
