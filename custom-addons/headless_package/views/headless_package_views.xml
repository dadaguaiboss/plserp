<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 无头件 Tree 视图 -->
    <record id="headless_package_view_tree" model="ir.ui.view">
        <field name="name">headless.package.tree</field>
        <field name="model">headless.package</field>
        <field name="arch" type="xml">
            <tree string="无头件列表"
                  decoration-danger="state == 'expired'"
                  decoration-success="state in ('confirmed', 'processed')"
                  decoration-warning="state == 'matched'"
                  decoration-info="state == 'matching'">
                <field name="name"/>
                <field name="tracking_number"/>
                <field name="sender_name"/>
                <field name="sender_phone"/>
                <field name="product_description"/>
                <field name="qty"/>
                <field name="receive_date"/>
                <field name="warehouse_id"/>
                <field name="match_confidence" widget="badge"
                       decoration-success="match_confidence == 'high'"
                       decoration-warning="match_confidence == 'medium'"
                       decoration-danger="match_confidence in ('low', 'none')"/>
                <field name="match_method"/>
                <field name="matched_sale_order_id"/>
                <field name="matched_aftersale_id"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('new', 'matching')"
                       decoration-warning="state == 'matched'"
                       decoration-success="state in ('confirmed', 'processed')"
                       decoration-danger="state == 'expired'"/>
            </tree>
        </field>
    </record>

    <!-- 无头件 Form 视图 -->
    <record id="headless_package_view_form" model="ir.ui.view">
        <field name="name">headless.package.form</field>
        <field name="model">headless.package</field>
        <field name="arch" type="xml">
            <form string="无头件">
                <header>
                    <button name="action_auto_match" type="object"
                            string="自动匹配" class="oe_highlight"
                            invisible="state not in ('new', 'matching')"/>
                    <button name="action_confirm_match" type="object"
                            string="确认匹配" class="oe_highlight"
                            invisible="state != 'matched'"/>
                    <button name="action_create_aftersale" type="object"
                            string="创建售后单"
                            invisible="state not in ('matched', 'confirmed')"/>
                    <button name="action_expire" type="object"
                            string="标记过期"
                            invisible="state not in ('new', 'matching')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,matching,matched,confirmed,processed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="包裹信息">
                            <field name="tracking_number"/>
                            <field name="sender_name"/>
                            <field name="sender_phone"/>
                            <field name="qty"/>
                            <field name="receive_date"/>
                            <field name="warehouse_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="匹配信息">
                            <field name="match_confidence"/>
                            <field name="match_method"/>
                            <field name="matched_sale_order_id"/>
                            <field name="matched_aftersale_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="product_description"/>
                    </group>
                    <notebook>
                        <page string="匹配产品" name="products">
                            <field name="product_ids">
                                <tree>
                                    <field name="default_code"/>
                                    <field name="name"/>
                                    <field name="list_price"/>
                                </tree>
                            </field>
                        </page>
                        <page string="备注" name="notes">
                            <field name="notes" placeholder="备注信息..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- 无头件 Search 视图 -->
    <record id="headless_package_view_search" model="ir.ui.view">
        <field name="name">headless.package.search</field>
        <field name="model">headless.package</field>
        <field name="arch" type="xml">
            <search string="搜索无头件">
                <field name="name"/>
                <field name="tracking_number"/>
                <field name="sender_name"/>
                <field name="sender_phone"/>
                <field name="product_description"/>
                <field name="matched_sale_order_id"/>
                <field name="matched_aftersale_id"/>
                <filter string="新建" name="filter_new"
                        domain="[('state', '=', 'new')]"/>
                <filter string="匹配中" name="filter_matching"
                        domain="[('state', '=', 'matching')]"/>
                <filter string="已匹配" name="filter_matched"
                        domain="[('state', '=', 'matched')]"/>
                <filter string="已确认" name="filter_confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="已处理" name="filter_processed"
                        domain="[('state', '=', 'processed')]"/>
                <filter string="已过期" name="filter_expired"
                        domain="[('state', '=', 'expired')]"/>
                <separator/>
                <filter string="高置信度" name="filter_high_confidence"
                        domain="[('match_confidence', '=', 'high')]"/>
                <filter string="待确认（中置信度）" name="filter_medium_confidence"
                        domain="[('match_confidence', '=', 'medium')]"/>
                <filter string="未匹配" name="filter_no_match"
                        domain="[('match_confidence', '=', 'none')]"/>
                <separator/>
                <group expand="0" string="分组">
                    <filter string="状态" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="置信度" name="group_confidence"
                            context="{'group_by': 'match_confidence'}"/>
                    <filter string="匹配方式" name="group_method"
                            context="{'group_by': 'match_method'}"/>
                    <filter string="仓库" name="group_warehouse"
                            context="{'group_by': 'warehouse_id'}"/>
                    <filter string="收件日期" name="group_date"
                            context="{'group_by': 'receive_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 无头件 Kanban 视图 -->
    <record id="headless_package_view_kanban" model="ir.ui.view">
        <field name="name">headless.package.kanban</field>
        <field name="model">headless.package</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile">
                <field name="name"/>
                <field name="tracking_number"/>
                <field name="sender_name"/>
                <field name="match_confidence"/>
                <field name="state"/>
                <field name="receive_date"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="state" widget="label_selection"
                                       options="{'classes': {
                                           'new': 'info',
                                           'matching': 'info',
                                           'matched': 'warning',
                                           'confirmed': 'success',
                                           'processed': 'primary',
                                           'expired': 'danger'
                                       }}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <span>物流: <field name="tracking_number"/></span>
                                <br/>
                                <span>寄件人: <field name="sender_name"/></span>
                                <br/>
                                <span>收件日期: <field name="receive_date"/></span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span>置信度: <field name="match_confidence"/></span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- 无头件 Action -->
    <record id="headless_package_action" model="ir.actions.act_window">
        <field name="name">无头件</field>
        <field name="res_model">headless.package</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="headless_package_view_search"/>
        <field name="context">{'search_default_filter_new': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                暂无无头件记录
            </p>
            <p>
                无头件是指无法匹配到对应订单的退货包裹。可以通过批量导入或手动创建来添加无头件。
            </p>
        </field>
    </record>

</odoo>
