<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- 规则1: 7天无理由+未使用 → 自动通过 -->
        <record id="rule_no_reason_7day" model="aftersale.rule">
            <field name="name">7天无理由退货自动通过</field>
            <field name="sequence">10</field>
            <field name="condition_type">no_reason_7day</field>
            <field name="result">auto_approve</field>
            <field name="threshold_days">7</field>
            <field name="active" eval="True"/>
        </record>

        <!-- 规则2: 质量问题+有图片 → 自动通过 -->
        <record id="rule_quality_with_image" model="aftersale.rule">
            <field name="name">质量问题有图片自动通过</field>
            <field name="sequence">20</field>
            <field name="condition_type">quality_with_image</field>
            <field name="result">auto_approve</field>
            <field name="active" eval="True"/>
        </record>

        <!-- 规则3: 超30天 → 人工复核 -->
        <record id="rule_over_30days" model="aftersale.rule">
            <field name="name">超30天人工复核</field>
            <field name="sequence">30</field>
            <field name="condition_type">over_30days</field>
            <field name="result">manual_review</field>
            <field name="threshold_days">30</field>
            <field name="active" eval="True"/>
        </record>

        <!-- 规则4: 高价值>1000元 → 人工复核 -->
        <record id="rule_high_value" model="aftersale.rule">
            <field name="name">高价值订单人工复核</field>
            <field name="sequence">5</field>
            <field name="condition_type">high_value</field>
            <field name="result">manual_review</field>
            <field name="threshold_amount">1000.0</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
